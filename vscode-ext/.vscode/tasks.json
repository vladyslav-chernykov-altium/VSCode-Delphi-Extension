{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "compile",
      "type": "shell",
      "command": "npm",
      "args": ["run", "compile"],
      "presentation": { "reveal": "silent" },
      "problemMatcher": "$tsc"
